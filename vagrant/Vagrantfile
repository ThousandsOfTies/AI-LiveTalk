# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # Ubuntu 24.04 LTS (ARM/x86 両対応の公式Box)
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.hostname = "ollama-vm"

  # ポートフォワーディング: ホスト 11434 -> VM 11434
  config.vm.network "forwarded_port", guest: 11434, host: 11434, host_ip: "127.0.0.1"

  # VirtualBox プロバイダー設定
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "ollama-vm"
    vb.memory = 8192   # 8GB RAM (最低4096, 推奨8192以上)
    vb.cpus   = 4
    vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
    vb.customize ["modifyvm", :id, "--ioapic", "on"]
  end

  # プロビジョニング: Ollama インストール & 設定
  config.vm.provision "shell", path: "provision.sh"

end
